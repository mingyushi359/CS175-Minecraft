<?xml version="1.0" encoding="UTF-8" ?>
<Mission xmlns="http://ProjectMalmo.microsoft.com"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <About>
        <Summary>Collect wood logs</Summary>
    </About>

    <ModSettings>
        <MsPerTick>5</MsPerTick>
    </ModSettings>

    <ServerSection>
        <ServerInitialConditions>
            <Time>
                <StartTime>1000</StartTime>
                <AllowPassageOfTime>false</AllowPassageOfTime>
            </Time>
            <Weather>clear</Weather>
            <AllowSpawning>false</AllowSpawning>
        </ServerInitialConditions>

        <ServerHandlers>
            <FlatWorldGenerator generatorString="3;7,2x3,2;1;" forceReset="true" />

            <DrawingDecorator>
                <DrawCuboid x1="0" y1="4" z1="0" x2="12" y2="8" z2="12" type="air" />
                <DrawCuboid x1="0" y1="3" z1="0" x2="12" y2="3" z2="12" type="grass" />

                <DrawCuboid x1="0" y1="3" z1="0" x2="12" y2="3" z2="0" type="stone" />
                <DrawCuboid x1="0" y1="3" z1="12" x2="12" y2="3" z2="12" type="stone" />
                <DrawCuboid x1="0" y1="3" z1="0" x2="0" y2="3" z2="12" type="stone" />
                <DrawCuboid x1="12" y1="3" z1="0" x2="12" y2="3" z2="12" type="stone" />

                <DrawBlock x="5" y="4" z="5" type="log" variant="oak" />
                <DrawBlock x="5" y="5" z="5" type="log" variant="oak" />
                <DrawBlock x="5" y="6" z="5" type="log" variant="oak" />

                <DrawBlock x="8" y="4" z="8" type="log" variant="oak" />
                <DrawBlock x="8" y="5" z="8" type="log" variant="oak" />
                <DrawBlock x="8" y="6" z="8" type="log" variant="oak" />

                <DrawCuboid x1="4" y1="7" z1="4" x2="6" y2="7" z2="6" type="leaves" variant="oak" />
                <DrawCuboid x1="7" y1="7" z1="7" x2="9" y2="7" z2="9" type="leaves" variant="oak" />
            </DrawingDecorator>

            <ServerQuitFromTimeUp timeLimitMs="40000" />
            <ServerQuitWhenAnyAgentFinishes />
        </ServerHandlers>
    </ServerSection>

    <AgentSection mode="Survival">
        <Name>Agent0</Name>

        <AgentStart>
            <Placement x="2.5" y="4.0" z="2.5" yaw="0" pitch="20" />
        </AgentStart>

        <AgentHandlers>
            <DiscreteMovementCommands>
                <ModifierList type="allow-list">
                    <command>move</command>
                    <command>turn</command>
                    <command>attack</command>
                </ModifierList>
            </DiscreteMovementCommands>

            <ObservationFromNearbyEntities>
                <Range name="entities" xrange="12" yrange="4" zrange="12" />
            </ObservationFromNearbyEntities>

            <ObservationFromGrid>
                <Grid absoluteCoords="true" name="board">
                    <min x="0" y="3" z="0" />
                    <max x="12" y="7" z="12" />
                </Grid>
            </ObservationFromGrid>

            <ObservationFromFullStats />

            <RewardForSendingCommand reward="-0.02" />

            <RewardForCollectingItem>
                <Item reward="25" type="log" />
            </RewardForCollectingItem>

            <AgentQuitFromCollectingItem>
                <Item amount="2" type="log" />
            </AgentQuitFromCollectingItem>

            <VideoProducer want_depth="false">
                <Width>160</Width>
                <Height>120</Height>
            </VideoProducer>
        </AgentHandlers>
    </AgentSection>
</Mission>